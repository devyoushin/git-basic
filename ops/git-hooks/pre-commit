#!/bin/sh
# pre-commit hook 템플릿
# 사용법:
#   cp templates/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# 또는 core.hooksPath 설정:
#   git config core.hooksPath templates/git-hooks

set -e

echo "🔍 pre-commit 검사 실행 중..."

# ─────────────────────────────────────────────
# 1. 대용량 파일 체크 (10MB 초과 차단)
# ─────────────────────────────────────────────
MAX_SIZE=$((10 * 1024 * 1024))
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        SIZE=$(stat -f%z "$FILE" 2>/dev/null || stat -c%s "$FILE" 2>/dev/null || echo 0)
        if [ "$SIZE" -gt "$MAX_SIZE" ]; then
            echo "❌ 파일이 너무 큽니다: $FILE ($(($SIZE / 1024 / 1024))MB)"
            echo "   Git LFS 사용: git lfs track \"$FILE\""
            exit 1
        fi
    fi
done

# ─────────────────────────────────────────────
# 2. .env 파일 실수 커밋 차단
# ─────────────────────────────────────────────
SENSITIVE=$(git diff --cached --name-only | grep -E "^\.env$|^\.env\.[^e]" || true)
if [ -n "$SENSITIVE" ]; then
    echo "❌ 민감 파일 커밋 차단: $SENSITIVE"
    echo "   .gitignore에 추가하세요."
    exit 1
fi

# ─────────────────────────────────────────────
# 3. Python 린트 (flake8)
# ─────────────────────────────────────────────
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep "\.py$" || true)
if [ -n "$STAGED_PY" ] && command -v flake8 >/dev/null 2>&1; then
    echo "  → Python 린트 검사 (flake8)..."
    flake8 $STAGED_PY --count --select=E9,F63,F7,F82 --show-source --statistics
    if [ $? -ne 0 ]; then
        echo "❌ Python 린트 오류. 커밋 중단."
        exit 1
    fi
fi

# ─────────────────────────────────────────────
# 4. JavaScript/TypeScript 린트 (ESLint)
# ─────────────────────────────────────────────
STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(js|ts|jsx|tsx)$" || true)
if [ -n "$STAGED_JS" ] && [ -f "package.json" ] && command -v npx >/dev/null 2>&1; then
    echo "  → JS/TS 린트 검사 (ESLint)..."
    npx eslint --no-error-on-unmatched-pattern $STAGED_JS
    if [ $? -ne 0 ]; then
        echo "❌ ESLint 오류. 커밋 중단."
        exit 1
    fi
fi

# ─────────────────────────────────────────────
# 5. Go 빌드 검사
# ─────────────────────────────────────────────
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM | grep "\.go$" || true)
if [ -n "$STAGED_GO" ] && command -v go >/dev/null 2>&1; then
    echo "  → Go 빌드 검사..."
    go build ./... 2>&1
    if [ $? -ne 0 ]; then
        echo "❌ Go 빌드 실패. 커밋 중단."
        exit 1
    fi
fi

echo "✅ pre-commit 검사 통과!"
exit 0
